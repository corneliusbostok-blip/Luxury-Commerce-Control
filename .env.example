# Kopiér til .env og udfyld:  cp .env.example .env
# Server indlæser .env først; derefter .env.example kun for variabler der stadig mangler (se server/load-env.js).

PORT=3000
PUBLIC_URL=http://localhost:3000

# Lokal udvikling: `npm run dev` loader server/set-local-dev.js og sætter VELDEN_LOCAL=1, så Stripe/OAuth
# bruger http://localhost:PORT (ignorerer PUBLIC_URL/URL/DEPLOY_PRIME_URL fra Netlify-kopi).
# Produktion: kør `npm start` uden det — eller sæt VELDEN_LOCAL=0 og korrekt PUBLIC_URL.
# Du kan også manuelt sætte VELDEN_LOCAL=1 i .env under udvikling.

# --- Database (Supabase) — KUN projekt-URL + service role til serveren. Det er IKKE eBay/Alibaba-nøgler. ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Påkrævet i prod til marketing-publikation + atomiske locks (kør SQL i Supabase):
# supabase/migrate_automation_lock_atomic_acquire.sql
# supabase/migrate_marketing_publish_guard.sql
# supabase/migrate_marketing_publish_guard_state.sql
# Sekunder: nyt provider-kald afvises mens status=publishing er “frisk” (split-brain-beskyttelse).
# MARKETING_UNCERTAINTY_SEC=1800
# Valider: node server/scripts/verify-system-guarantees.js
# KUN lokal udvikling — usikker på tværs af processer:
# ALLOW_NON_ATOMIC_LOCKS=1

# Google AI Studio — Gemini
GEMINI_API_KEY=your_gemini_api_key
# Sekundær nøgle: bruges automatisk ved 401/403/429, kvote, serverfejl eller netværksfejl (sourcing, CEO, TTS).
# GEMINI_API_KEY_2=your_second_gemini_api_key
# (alias) GEMINI_SECONDARY_API_KEY=same_as_backup
# Alternativt: flere nøgler kommasepareret (første prøves først; duplikater fjernes).
# GEMINI_API_KEYS=key_one,key_two
# Valgfri tekstmodel (sourcing + CEO). IKKE gemini-1.0-pro (404 på nuværende API). Standard: gemini-1.5-flash.
# GEMINI_MODEL=gemini-1.5-flash
# Admin voice-bot TTS (valgfrit — standard: gemini-2.5-flash-preview-tts + Achird)
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Achird
# GEMINI_TTS_MAX_CHARS=4500

# Stripe — brug den fulde Secret key fra Dashboard → API keys (sk_test_… eller sk_live_…), IKKE pk_test (publishable).
# Placeholder "sk_test_..." giver Checkout failed / Invalid API Key. Ingen anførselstegn omkring nøglen.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=dkk

VELDEN_PRICE_OFFSET_MIN=200
VELDEN_PRICE_OFFSET_MAX=300
VELDEN_PRICE_MIN=99

DISCOVERY_SEED_URLS=
DISCOVERY_SEED_SHIRTS=https://syncee.com/page/mens-clothing-dropshipping/
DISCOVERY_SEED_TROUSERS=
DISCOVERY_SEED_OUTERWEAR=
DISCOVERY_SEED_KNITWEAR=
DISCOVERY_SEED_SHOES=
DISCOVERY_SEED_WATCHES=
DISCOVERY_SEED_ACCESSORIES=
DISCOVERY_SEED_OTHER=
DISCOVERY_FETCH_TIMEOUT_MS=18000
DISCOVERY_MAX_PAGE_FETCHES=28
DISCOVERY_DEFAULT_SUPPLIER_COUNTRY=DK
# Background sourcing — default 10 min if both unset. Prefer minutes (mindre fejl end ms).
SOURCING_INTERVAL_MINUTES=10
# SOURCING_INTERVAL_MS=600000

# Admin-dashboard (Remove, import, sourcing-chat …): samme streng som i X-Admin-Secret i browseren.
# Brug en selvvalgt kode — aldrig Supabase service role key eller eBay Client secret her.
ADMIN_SECRET=bahr-dashboard

# TikTok marketing (Content Posting API — PHOTO via PULL_FROM_URL). OAuth: admin Marketing → Connect; app keys TIKTOK_CLIENT_KEY / TIKTOK_CLIENT_SECRET.
# TIKTOK_SCOPES=user.info.basic,video.publish
# Privacy for direct post (TikTok app audit may require SELF_ONLY until approved): PUBLIC_TO_EVERYONE | SELF_ONLY | MUTUAL_FOLLOW_FRIENDS | …
# TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# --- eBay (kun server-indstillinger til «Test leverandør-adgang» / OAuth — IKKE dine App ID/secret) ---
# eBay App ID + Client secret + OAuth-token gemmes under Indstillinger → Markedspladser (Supabase store_config), ikke her.
# App ID med «-SBX-» vælger automatisk sandbox-endpoint; ellers: EBAY_USE_SANDBOX=true for sandbox-nøgler.
# EBAY_USE_SANDBOX=false  # tving production hvis nødvendigt
# EBAY_MARKETPLACE_ID=EBAY_DE   # hvis Browse-ping fejler (standard er EBAY_US); se eBay MarketplaceIdEnum
# EBAY_ACCEPT_LANGUAGE=da-DK,da;q=0.9,en;q=0.8   # valgfrit til Browse API
# EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope   # valgfrit; flere scopes adskilt med mellemrum — kopier fra Application Keys → OAuth scopes
# EBAY_DISCOVERY_QUERY=vintage watch   # fallback når butikken ikke har tilladte kategorier (komma/linje = flere, vælges tilfældigt)

SUPPLIER_NOTIFY_EMAIL=
